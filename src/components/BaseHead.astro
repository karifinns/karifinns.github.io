---
import { siteDescription, siteTitle, withBase } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
}

const {
  title = siteTitle,
  description = siteDescription,
  canonicalPath = Astro.url.pathname,
  ogType = "website",
  publishedTime,
  modifiedTime
} = Astro.props;

const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const basedCanonicalPath = canonicalPath.startsWith(import.meta.env.BASE_URL)
  ? canonicalPath
  : withBase(canonicalPath);
const canonicalUrl = new URL(basedCanonicalPath, Astro.site);
const rssUrl = new URL(withBase("/rss.xml"), Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content="index,follow" />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="is_IS" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
{publishedTime && ogType === "article" && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{modifiedTime && ogType === "article" && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<link rel="alternate" type="application/rss+xml" title={`${siteTitle} XML straumur`} href={rssUrl} />
