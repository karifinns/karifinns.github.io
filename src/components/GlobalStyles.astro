<style is:global>
  :root {
    --bg: #f3eee5;
    --surface: #ece6da;
    --text: #2a241f;
    --muted: #6f655a;
    --soft: #93887b;
    --line: rgba(42, 36, 31, 0.095);
    --line-strong: rgba(42, 36, 31, 0.155);
    --code-bg: rgba(42, 36, 31, 0.035);
    --max-width: 36.75rem;
    --wide-width: 41.5rem;
    --body-font: "Source Serif 4", "Iowan Old Style", "Palatino Linotype", "URW Palladio L",
      Georgia, serif;
    --display-font: "Baskerville", "Libre Baskerville", "Iowan Old Style", "Times New Roman",
      serif;
    --ui-font: "Avenir Next", "Helvetica Neue", "Inter", "Segoe UI", sans-serif;
  }

  html {
    font-size: 18px;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--body-font);
    line-height: 1.78;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration-color: rgba(38, 33, 28, 0.2);
    text-underline-offset: 0.16em;
    transition: color 140ms ease, text-decoration-color 140ms ease, border-color 140ms ease,
      opacity 140ms ease;
  }

  a:hover {
    text-decoration-color: currentColor;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .page-shell {
    min-height: 100vh;
    padding: 2.7rem 1.35rem 6.2rem;
  }

  .page-header,
  .page-content {
    width: min(100%, var(--wide-width));
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 4.5rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.62rem 0.95rem;
    font-family: var(--ui-font);
    font-size: 0.71rem;
    letter-spacing: 0.095em;
    text-transform: uppercase;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--muted);
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--text);
  }

  .page-content > * {
    width: min(100%, var(--max-width));
    margin-left: auto;
    margin-right: auto;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--display-font);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(3rem, 9vw, 5.45rem);
  }

  h2 {
    font-size: clamp(1.58rem, 4vw, 2.05rem);
    margin-top: 4.7rem;
  }

  h3 {
    font-size: 1.22rem;
    margin-top: 2rem;
  }

  p,
  ul,
  ol,
  pre,
  blockquote {
    margin: 0 0 1.58rem;
  }

  ul,
  ol {
    padding-left: 1.2rem;
  }

  .prose ul:not(.tag-list):not(.section-links) > li + li,
  .prose ol:not(.tag-list):not(.section-links) > li + li,
  .simple-list li + li {
    margin-top: 0.4rem;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 3.25rem auto;
    width: min(100%, var(--max-width));
  }

  small,
  .meta,
  time {
    color: var(--muted);
  }

  code,
  pre {
    font-family: "SFMono-Regular", "Menlo", "Monaco", "Liberation Mono", monospace;
    font-size: 0.88rem;
  }

  code {
    background: var(--code-bg);
    padding: 0.08rem 0.28rem;
    border-radius: 0.2rem;
  }

  pre {
    background: var(--code-bg);
    padding: 1.1rem 1.2rem;
    overflow-x: auto;
    border-radius: 0.2rem;
    border: 1px solid var(--line);
  }

  pre code {
    background: transparent;
    padding: 0;
  }

  blockquote {
    padding-left: 1.1rem;
    border-left: 1px solid var(--line-strong);
    color: var(--muted);
  }

  .intro {
    margin-bottom: 5.1rem;
    padding-bottom: 2.8rem;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--ui-font);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.15rem;
  }

  .lede {
    color: var(--muted);
    font-size: 1rem;
    max-width: 29rem;
  }

  .section-links,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.95rem;
    padding: 0;
    list-style: none;
  }

  .section-links a,
  .tag-list a,
  .tag-list span {
    text-decoration: none;
    color: var(--muted);
  }

  .section-links a:hover,
  .tag-list a:hover {
    color: var(--text);
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .writing-list li {
    border-top: 1px solid var(--line);
    padding: 1.3rem 0 1.45rem;
  }

  .writing-list li:last-child {
    border-bottom: 1px solid var(--line);
  }

  .subscribe-module {
    margin-top: 4.9rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .subscribe-module-article {
    margin-top: 5.2rem;
  }

  .subscribe-module h2 {
    font-size: 1.42rem;
    margin: 0 0 0.75rem;
  }

  .subscribe-module-article h2 {
    font-size: 1.24rem;
  }

  .subscribe-copy,
  .subscribe-help {
    color: var(--muted);
    font-size: 0.98rem;
    max-width: 30rem;
    margin-bottom: 1rem;
  }

  .subscribe-help {
    font-family: var(--ui-font);
    font-size: 0.74rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--soft);
    margin-bottom: 0;
  }

  .subscribe-rss-link {
    text-transform: none;
    letter-spacing: 0;
    color: var(--muted);
    text-decoration: none;
  }

  .subscribe-rss-link:hover,
  .subscribe-rss-link:focus-visible {
    color: var(--text);
  }

  .subscribe-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .subscribe-input,
  .subscribe-button {
    border: 1px solid var(--line-strong);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
  }

  .subscribe-input {
    flex: 1 1 16rem;
    min-width: 0;
    padding: 0.78rem 0.88rem;
  }

  .subscribe-input::placeholder {
    color: var(--soft);
  }

  .subscribe-input:focus,
  .subscribe-button:focus {
    outline: none;
    border-color: rgba(42, 36, 31, 0.35);
  }

  .subscribe-button {
    flex: 0 0 auto;
    padding: 0.78rem 1rem;
    font-family: var(--ui-font);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .subscribe-button:hover {
    border-color: rgba(42, 36, 31, 0.3);
  }

  .subscribe-honeypot,
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .writing-link {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.4rem;
    text-decoration: none;
  }

  .writing-title h2,
  .writing-title h3 {
    font-size: 1.28rem;
    margin: 0;
    line-height: 1.18;
  }

  .writing-list time {
    flex: 0 0 auto;
    font-family: var(--ui-font);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--soft);
    padding-top: 0.24rem;
  }

  .writing-list p {
    color: var(--muted);
    margin-top: 0.55rem;
    margin-bottom: 0;
    max-width: 31rem;
    font-size: 0.97rem;
  }

  .writing-list a:hover .writing-title h2,
  .writing-list a:hover .writing-title h3,
  .writing-list a:focus-visible .writing-title h2,
  .writing-list a:focus-visible .writing-title h3 {
    color: var(--muted);
  }

  .writing-list a:hover time,
  .writing-list a:focus-visible time {
    color: var(--muted);
  }

  .writing-list-home li {
    padding: 1.6rem 0 1.7rem;
  }

  .writing-list-home .writing-title h3 {
    font-size: 1.48rem;
  }

  .site-title {
    margin-bottom: 1rem;
    max-width: 16rem;
  }

  .site-tagline {
    font-family: var(--body-font);
    font-size: 0.84rem;
    font-style: italic;
    color: var(--soft);
    margin-bottom: 0;
    max-width: 19rem;
    letter-spacing: 0.01em;
  }

  .intro-home {
    margin-bottom: 5.8rem;
    padding-bottom: 2.9rem;
  }

  .home-writing {
    margin-bottom: 6.4rem;
  }

  .home-writing h2 {
    margin-top: 0;
    margin-bottom: 1.75rem;
  }

  .home-navline {
    width: 100%;
    margin-top: 0.2rem;
  }

  .home-navline .section-links {
    gap: 0.45rem 1rem;
    justify-content: flex-start;
  }

  .home-navline .section-links a {
    font-family: var(--ui-font);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    color: var(--soft);
  }

  .home-navline .section-links a:hover,
  .home-navline .section-links a:focus-visible {
    color: var(--text);
  }

  .prose-header {
    margin-bottom: 3.3rem;
    padding-bottom: 2.2rem;
    border-bottom: 1px solid var(--line);
  }

  .prose-header h1 {
    font-size: clamp(2.75rem, 7vw, 4.25rem);
    margin-bottom: 1rem;
    max-width: 31rem;
  }

  .prose-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.8rem;
    font-family: var(--ui-font);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .prose {
    font-size: clamp(1.08rem, 1rem + 0.18vw, 1.15rem);
    line-height: 1.95;
    position: relative;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote,
  .prose pre {
    max-width: 31.5rem;
  }

  .prose p {
    margin-bottom: 1.72rem;
  }

  .prose p:has(> img:only-child) {
    max-width: 35.5rem;
    margin-top: 2.35rem;
    margin-bottom: 2.75rem;
  }

  .prose p > img:only-child {
    display: block;
    width: 100%;
    max-width: none;
    height: auto;
    margin: 0 auto;
    border: 1px solid var(--line);
  }

  .prose > p:first-of-type {
    font-size: 1.08em;
    color: color-mix(in srgb, var(--text) 88%, var(--muted));
  }

  .prose h2,
  .prose h3 {
    margin-top: 3.55rem;
    margin-bottom: 1.1rem;
  }

  .prose h2 {
    font-size: clamp(1.48rem, 3vw, 1.82rem);
  }

  .prose h3 {
    font-size: 1.22rem;
  }

  .prose a {
    text-decoration-thickness: 0.06em;
  }

  .prose sup {
    font-family: var(--ui-font);
    font-size: 0.67em;
    line-height: 0;
    vertical-align: 0.5em;
  }

  .prose sup a {
    text-decoration: none;
    color: var(--soft);
  }

  .prose sup a:hover,
  .prose sup a:focus-visible {
    color: var(--text);
  }

  .prose .footnotes {
    margin-top: 4.4rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--line);
    font-size: 0.88rem;
    color: var(--muted);
  }

  .prose .footnotes ol {
    padding-left: 1.1rem;
  }

  .prose .footnotes li {
    padding-left: 0.15rem;
  }

  .prose .footnotes p {
    margin-bottom: 0.8rem;
  }

  .prose .footnote-backref {
    text-decoration: none;
    color: var(--soft);
  }

  .sidenote-layer {
    display: none;
  }

  @media (min-width: 1200px) {
    .writing-article.has-sidenotes {
      overflow: visible;
    }

    .writing-article.has-sidenotes .footnotes {
      display: none;
    }

    .writing-article.has-sidenotes .sidenote-layer {
      display: block;
      position: absolute;
      top: 0;
      left: calc(100% + 2.6rem);
      width: min(15rem, calc((100vw - var(--wide-width)) / 2 + 10rem));
      pointer-events: none;
    }

    .sidenote {
      position: absolute;
      left: 0;
      width: 100%;
      font-family: var(--ui-font);
      font-size: 0.76rem;
      line-height: 1.58;
      color: var(--muted);
      padding-top: 0.1rem;
      border-top: 1px solid var(--line);
      opacity: 0.92;
      transition: opacity 140ms ease, color 140ms ease, border-color 140ms ease;
      pointer-events: auto;
    }

    .sidenote.is-active {
      color: var(--text);
      border-color: var(--line-strong);
      opacity: 1;
    }

    .sidenote p {
      margin-bottom: 0.65rem;
    }

    .sidenote-number {
      display: inline-block;
      min-width: 1.1rem;
      margin-right: 0.28rem;
      color: var(--soft);
    }
  }

  .project-list,
  .about-copy {
    width: min(100%, 31.5rem);
    margin-left: auto;
    margin-right: auto;
  }

  .project-entry {
    padding: 1.35rem 0 1.45rem;
    border-top: 1px solid var(--line);
  }

  .project-entry:last-child {
    border-bottom: 1px solid var(--line);
  }

  .project-entry h2 {
    margin: 0 0 0.45rem;
    font-size: 1.28rem;
  }

  .project-entry h2 a {
    text-decoration: none;
  }

  .project-entry h2 a:hover,
  .project-entry h2 a:focus-visible {
    color: var(--muted);
  }

  .project-entry p {
    margin: 0;
    max-width: 29rem;
    color: var(--muted);
  }

  .about-copy p {
    margin-bottom: 1.42rem;
    max-width: 31rem;
  }

  .simple-list {
    list-style: none;
    padding: 0;
  }

  .simple-list li {
    padding: 1.05rem 0 1.15rem;
    border-top: 1px solid var(--line);
  }

  .simple-list li:last-child {
    border-bottom: 1px solid var(--line);
  }

  .not-found {
    padding-top: 12vh;
  }

  @media (max-width: 640px) {
    html {
      font-size: 17px;
    }

    .page-shell {
      padding: 1.4rem 1rem 3.5rem;
    }

    .page-header {
      margin-bottom: 2.6rem;
    }

    .writing-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    .site-title {
      max-width: none;
    }

    .intro-home {
      margin-bottom: 4.8rem;
    }

    .writing-list li,
    .writing-list-home li {
      padding: 1.05rem 0 1.15rem;
    }

    .subscribe-form {
      flex-direction: column;
      align-items: stretch;
    }

    .subscribe-help {
      line-height: 1.5;
    }

    .project-list,
    .about-copy {
      width: 100%;
    }
  }
</style>
