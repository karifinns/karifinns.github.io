---
import BaseHead from "../components/BaseHead.astro";
import GlobalStyles from "../components/GlobalStyles.astro";
import SiteNav from "../components/SiteNav.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  showNav?: boolean;
}

const { title, description, canonicalPath, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="is">
  <head>
    <BaseHead title={title} description={description} canonicalPath={canonicalPath} />
    <GlobalStyles />
  </head>
  <body>
    <div class="page-shell">
      {showNav && (
        <header class="page-header">
          <SiteNav />
        </header>
      )}
      <main class="page-content">
        <slot />
      </main>
    </div>
  </body>
</html>
