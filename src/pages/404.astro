---
import MainLayout from "../layouts/MainLayout.astro";
import { withBase } from "../lib/site";
---

<MainLayout
  title="404"
  description="Ekki tókst að finna síðuna sem þú leitaðir að."
>
  <section class="not-found">
    <span class="eyebrow">404</span>
    <h1>Síðan fannst ekki.</h1>
    <p class="lede">
      Síðan sem þú leitaðir að virðist annaðhvort ekki lengur vera hér eða hafa aldrei verið birt.
    </p>
    <p><a href={withBase("/")}>Fara á forsíðu</a></p>
  </section>
</MainLayout>
