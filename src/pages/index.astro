---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import WritingList from "../components/WritingList.astro";
import { navigation, siteDescription, siteTagline, siteTitle, withBase } from "../lib/site";
import { getVisibleWriting } from "../lib/writing";

const writing = getVisibleWriting(await getCollection("writing")).slice(0, 5);
---

<MainLayout title={siteTitle} description={siteDescription} showNav={false}>
  <section class="intro intro-home">
    <h1 class="site-title">{siteTitle}</h1>
    <p class="site-tagline">{siteTagline}</p>
  </section>

  <section class="home-writing" aria-labelledby="recent-writing">
    <h2 id="recent-writing">Nýleg skrif</h2>
    <WritingList entries={writing} headingLevel="h3" variant="home" />
  </section>

  <nav class="home-navline" aria-label="Leiðsögn">
    <ul class="section-links">
      {navigation.map((item) => (
        <li><a href={withBase(item.href)}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</MainLayout>
