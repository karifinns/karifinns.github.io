---
import { getCollection } from "astro:content";
import MainLayout from "../../../layouts/MainLayout.astro";
import WritingList from "../../../components/WritingList.astro";
import { getVisibleWriting, slugifyTag } from "../../../lib/writing";

export async function getStaticPaths() {
  const entries = getVisibleWriting(await getCollection("writing"));
  const tags = [...new Set(entries.flatMap((entry) => entry.data.tags))];

  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: {
      tag,
      entries: entries.filter((entry) => entry.data.tags.includes(tag))
    }
  }));
}

const { tag, entries } = Astro.props;
---

<MainLayout
  title={`Efnisorð: ${tag}`}
  description={`Skrif merkt efnisorðinu ${tag}.`}
  canonicalPath={`/writing/tags/${slugifyTag(tag)}/`}
>
  <section class="intro">
    <span class="eyebrow">Efnisorð</span>
    <h1>{tag}</h1>
    <p class="lede">Önnur leið inn í textana.</p>
  </section>

  <WritingList entries={entries} showDescription={true} />
</MainLayout>
